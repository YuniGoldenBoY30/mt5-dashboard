# =========================
# MT5 Dashboard - Variables de entorno
# =========================
# Copiar a .env y ajustar valores.

# ── Base de datos ─────────────────────────────────────────────
# PostgreSQL (producción)
POSTGRES_DB=mt5_dashboard
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_PORT=5433

# Backend leerá DATABASE_URL desde estas variables en docker-compose
# Para desarrollo local sin Docker, puedes设置 DATABASE_URL directamente:
# DATABASE_URL=postgresql://dashboard:change_me_strong_password@localhost:5433/mt5_dashboard
# o SQLite: DATABASE_URL=sqlite:///./dev.db

# ── Backend FastAPI ────────────────────────────────────────────
BACKEND_PORT=8000
SECRET_KEY=change_me_super_secret_key_64_chars_minimum_length_here
SESSION_TIMEOUT_MIN=30

# URLs de los VPS que exponen status.json (legacy polling)
# Formato: https://IP:PUERTO/status.json,https://IP2:PUERTO2/status.json
VPS_ENDPOINTS=https://vps1.example.com:8443/status.json,https://vps2.example.com:8443/status.json

# Token secreto para validar requests VPS (opcional, pendiente implementar)
VPS_SECRET_TOKEN=change_this_vps_token_32chars

# URL del frontend (para CORS estricto)
FRONTEND_URL=http://localhost:3001

# ── Cuentas admin (creadas en primer startup) ──────────────────
ADMIN_TEAM_PASSWORD=team123_strong_password
ADMIN_DEV_PASSWORD=dev123_strong_password

# ── SMTP / Alertas por email ───────────────────────────────────
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_cuenta@gmail.com
SMTP_PASSWORD=tu_app_password
SMTP_USE_TLS=true
ALERT_SENDER_EMAIL=alerts@tu_dominio.com
# Lista separada por comas
ALERT_RECIPIENT_EMAILS=admin1@example.com,admin2@example.com

# ── Frontend ───────────────────────────────────────────────────
# Puerto host para contenedor frontend
FRONTEND_PORT=3001
# URL API (consumida por frontend en runtime)
VITE_API_URL=http://localhost:8000

# ── Nginx ──────────────────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
